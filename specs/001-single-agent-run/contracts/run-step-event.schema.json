{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scaffolder/specs/001-single-agent-run/contracts/run-step-event.schema.json",
  "title": "RunEvent",
  "description": "Common envelope for every event on a run's durable, append-only, per-run event log. Ordering within a run is by 'sequence' only; 'timestamp' is informational. Tool events additionally carry a 'callId' that correlates a tool.call with its tool.result / tool.rejected / tool.error.",
  "type": "object",
  "required": ["runId", "sequence", "type", "timestamp", "payload"],
  "properties": {
    "runId": {
      "type": "string",
      "format": "uuid"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1,
      "description": "Per-run monotonic value giving total ordering within a run. Also surfaced as the SSE Last-Event-ID / lastSeenSequence resumable cursor."
    },
    "type": {
      "type": "string",
      "enum": [
        "run.started",
        "run.completed",
        "run.failed",
        "run.bounded",
        "agent.message",
        "tool.call",
        "tool.result",
        "tool.rejected",
        "tool.error",
        "review.requested",
        "review.approved",
        "review.declined",
        "merge.completed",
        "merge.failed"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Informational only. MUST NOT be used to order events."
    },
    "callId": {
      "type": "string",
      "format": "uuid",
      "description": "Required on tool events (tool.call, tool.result, tool.rejected, tool.error). tool.result/tool.rejected/tool.error echo the originating tool.call's callId."
    },
    "payload": {
      "oneOf": [
        { "$ref": "#/$defs/LifecyclePayload" },
        { "$ref": "#/$defs/AgentMessagePayload" },
        { "$ref": "#/$defs/ToolCallPayload" },
        { "$ref": "#/$defs/ToolResultPayload" },
        { "$ref": "#/$defs/ToolRejectedPayload" },
        { "$ref": "#/$defs/ToolErrorPayload" },
        { "$ref": "#/$defs/ReviewPayload" },
        { "$ref": "#/$defs/MergePayload" }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "enum": ["tool.call", "tool.result", "tool.rejected", "tool.error"]
          }
        }
      },
      "then": {
        "required": ["callId"]
      }
    }
  ],
  "$defs": {
    "LifecyclePayload": {
      "type": "object",
      "description": "Payload for run.started | run.completed | run.failed | run.bounded.",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "queued",
            "running",
            "completed",
            "failed",
            "bounded",
            "awaiting_review",
            "approved",
            "declined",
            "merged",
            "merge_conflict"
          ]
        },
        "reason": { "type": "string" }
      }
    },
    "AgentMessagePayload": {
      "type": "object",
      "description": "Payload for agent.message.",
      "required": ["message"],
      "properties": {
        "message": { "type": "string" }
      }
    },
    "ToolCallPayload": {
      "type": "object",
      "description": "Payload for tool.call.",
      "required": ["toolName", "path"],
      "properties": {
        "toolName": { "type": "string", "enum": ["read_file", "write_file"] },
        "path": { "type": "string" }
      }
    },
    "ToolResultPayload": {
      "type": "object",
      "description": "Payload for tool.result (successful tool outcome).",
      "required": ["toolName", "result"],
      "properties": {
        "toolName": { "type": "string", "enum": ["read_file", "write_file"] },
        "result": { "type": "string", "const": "success" },
        "content": { "type": "string" }
      }
    },
    "ToolRejectedPayload": {
      "type": "object",
      "description": "Payload for tool.rejected (denied by sandbox, distinct from tool.result).",
      "required": ["toolName", "errorCode"],
      "properties": {
        "toolName": { "type": "string", "enum": ["read_file", "write_file"] },
        "errorCode": {
          "type": "string",
          "enum": ["PATH_ESCAPE", "PERMISSION"]
        },
        "reason": { "type": "string" }
      }
    },
    "ToolErrorPayload": {
      "type": "object",
      "description": "Payload for tool.error (operation failed, distinct from tool.result).",
      "required": ["toolName", "errorCode"],
      "properties": {
        "toolName": { "type": "string", "enum": ["read_file", "write_file"] },
        "errorCode": {
          "type": "string",
          "enum": ["NOT_FOUND", "PERMISSION", "UNKNOWN"]
        },
        "reason": { "type": "string" }
      }
    },
    "ReviewPayload": {
      "type": "object",
      "description": "Payload for review.requested | review.approved | review.declined.",
      "properties": {
        "reviewer": { "type": "string" },
        "comment": { "type": "string" }
      }
    },
    "MergePayload": {
      "type": "object",
      "description": "Payload for merge.completed | merge.failed.",
      "properties": {
        "mergeResult": {
          "type": "string",
          "enum": ["merged", "conflict", "failed"]
        },
        "reason": { "type": "string" }
      }
    }
  }
}
