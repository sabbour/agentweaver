{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Agentweaver": "Information"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "TimestampFormat": "HH:mm:ss ",
        "SingleLine": true
      }
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Runs": {
    "AllowedRepositoryRoots": []
  },
  "Sandbox": {
    "AgentExecutionMode": "in-api",
    "AgentHost": {
      "Port": 8088,
      "Scheme": "https",
      "A2APath": "/a2a/agent"
    },
    "Kubernetes": {
      "Namespace": "agentweaver",
      "TemplateRef": "agentweaver-sandbox",
      "TimeoutSeconds": 600
    }
  },
  "Auth": {
    "GitHub": {
      "AllowedOrg": "microsoft",
      "Scopes": "repo read:user read:org copilot"
    },
    "OAuth": {
      "SigningKey": "",
      "Issuer": "",
      "Audience": "",
      "AllowedRedirectUriPrefixes": []
    }
  },
  "AllowedHosts": "*"
}
