{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Runs": {
    "AllowedRepositoryRoots": []
  },
  "Sandbox": {
    "AgentExecutionMode": "in-api",
    "AgentHost": {
      "Port": 8088,
      "Scheme": "https",
      "A2APath": "/a2a/agent"
    },
    "Kubernetes": {
      "Namespace": "agentweaver",
      "TemplateRef": "agentweaver-sandbox",
      "TimeoutSeconds": 600
    }
  },
  "Auth": {
    "GitHub": {
      "AllowedOrg": "microsoft",
      "Scopes": "repo read:user read:org"
    },
    "OAuth": {
      "SigningKey": "",
      "Issuer": "",
      "Audience": "",
      "AllowedRedirectUriPrefixes": []
    }
  },
  "AllowedHosts": "*"
}
