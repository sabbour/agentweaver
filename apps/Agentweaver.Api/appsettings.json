{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Runs": {
    "AllowedRepositoryRoots": []
  },
  "Sandbox": {
    "Kubernetes": {
      "Namespace": "agentweaver",
      "TemplateRef": "agentweaver-sandbox",
      "TimeoutSeconds": 600
    }
  },
  "Auth": {
    "GitHub": {
      "AllowedOrg": "microsoft"
    }
  },
  "AllowedHosts": "*"
}
