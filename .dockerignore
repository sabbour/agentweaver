# Git
.git
.gitignore

# IDE
.vs
.vscode
.idea

# Development secrets (git-ignored, must not leak to images)
**/appsettings.Development.json

# Squad / AI
.squad
.copilot
.github/agents

# Node
node_modules

# .NET build artifacts (but not checked-in native binaries)
**/bin/Debug
**/bin/Release
**/obj

# Test results
**/TestResults
tests

# Scripts and specs (not needed in runtime images)
scripts
specs
/*.md

# Large non-runtime directories
**/node_modules
.squad
.specify
