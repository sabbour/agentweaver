# Git
.git
.gitignore

# IDE
.vs
.vscode
.idea

# Development secrets (git-ignored, must not leak to images)
**/appsettings.Development.json

# Squad / AI
.squad
.copilot
.github/agents

# Node
node_modules

# .NET build artifacts (but not checked-in native binaries)
**/bin/Debug
**/bin/Release
**/obj

# Test results
**/TestResults
tests

# Scripts, specs, and docs (not needed in runtime images; docs/.vitepress/dist
# is generated build output that can race az acr build's context tar)
scripts
specs
docs
/*.md

# Large non-runtime directories
**/node_modules
.squad
.specify
