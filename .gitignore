# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream
.squad/.cache/

# Node
node_modules/
npm-debug.log*

# TypeScript build output
dist/
*.tsbuildinfo

# Misc
.DS_Store

# Build output
apps/*/bin/
apps/*/obj/
packages/*/bin/
packages/*/obj/
# Un-ignore bundled mxc executor source binaries (MIT-licensed, ships with the package)
!packages/Scaffolder.SandboxExec/bin/
!packages/Scaffolder.SandboxExec/bin/arm64/
!packages/Scaffolder.SandboxExec/bin/arm64/**
!packages/Scaffolder.SandboxExec/bin/x64/
!packages/Scaffolder.SandboxExec/bin/x64/**
# Re-ignore .NET build output subdirectories inside the SandboxExec bin/ folder
packages/Scaffolder.SandboxExec/bin/Debug/
packages/Scaffolder.SandboxExec/bin/Release/
tests/*/bin/
tests/*/obj/

# Node.js
apps/web/node_modules/
apps/web/dist/

# .NET user files
*.user
*.suo
.vs/
*.userprefs

# Rider
.idea/

# Environment
.env
.env.local
apps/Scaffolder.Api/appsettings.Development.json

obj/

# Test results
[Tt]est[Rr]esults/

# Vite build cache
apps/web/.vite/
