{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=scaffolder.db"
  },
  "Scaffolder": {
    "RunRoot": "./runs",
    "DefaultMaxSteps": 200,
    "DefaultMaxDurationSeconds": 1800,
    "ModelSources": {
      "CopilotSdk": {
        "Enabled": true
      },
      "MicrosoftFoundry": {
        "Enabled": true,
        "Endpoint": null
      }
    }
  },
  "Urls": "http://localhost:3000"
}
