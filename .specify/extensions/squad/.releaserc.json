{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "docs/CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "sed -i 's/^  version: \".*\"/  version: \"${nextRelease.version}\"/' extension.yml && sed -i 's|/archive/refs/tags/v[0-9]*\\.[0-9]*\\.[0-9]*\\.zip|/archive/refs/tags/${nextRelease.gitTag}.zip|g' README.md"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["docs/CHANGELOG.md", "extension.yml", "README.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
